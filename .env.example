# Optional SMTP configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-user@example.com
SMTP_PASSWORD=replace-with-an-app-password
SMTP_FROM=your-user@example.com
SMTP_USE_TLS=true

# Local document storage
DOCUMENT_DOWNLOAD_DIR=downloads

# Generic source configuration for a future public adapter
DOCUMENT_SOURCE_URL=https://example.com/documents
ALLOWED_DOWNLOAD_DOMAIN=example.com
